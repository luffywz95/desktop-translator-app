{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Desktop Translator (main.pyw)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.pyw",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
